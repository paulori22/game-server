# Linux: set to $(id -u) / $(id -g) so the app user matches your bind-mounted checkout.
HOST_UID=1000
HOST_GID=1000

APP_PORT=3000
# docker compose (dev): Postgres uses DB_* on first boot; the app service sets DB_HOST=db. After changing DB username/db name/password, delete .docker/dbdata so Postgres re-initializes.
# docker compose -f docker-compose-prod.yaml: same DB_*; app uses DB_HOST=db. Postgres data: .docker/dbdata-prod (delete that folder to re-init after credential changes).
# AUTHORIZED_API_KEYS is required for the app container (use a strong value in real deployments).
DB_HOST=localhost
DB_PORT=5432
DB_DATABASE=laser_defender
DB_USERNAME=postgres
DB_PASSWORD=root
DB_SSL=false
AUTHORIZED_API_KEYS=apikeypass,apikeypass2